{
  "name": "octo-portfolio",
  "version": "0.0.1",
  "private": true,
  "description": "Octo-Portfolio – a space-themed developer portfolio built with TurboRepo, PNPM, Nuxt.js and Nitro",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "generate": "turbo run generate",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "husky",
    "format": "prettier --write \"**/*.{js,vue,json,md,css}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "eslint": "^9.18.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.4"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix"
    ],
    "*.{js,vue,json,md,css}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@9.15.9"
}
